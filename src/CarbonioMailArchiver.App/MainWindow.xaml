<Window x:Class="CarbonioMailArchiver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Carbonio Mail Archiver" Height="620" MinHeight="560" Width="920" MinWidth="780">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Carbonio Mail Archiver" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Fase A: configurazione locale, credenziali protette, logging e base MVVM/DI." Foreground="#555" Margin="0,4,0,18" />
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Connessione">
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Base URL" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox Grid.Column="1" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="1" Text="SOAP URL" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SoapUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="2" Text="Account email" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="3" Text="Password" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="PasswordInput" PasswordChanged="PasswordInput_OnPasswordChanged" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="4" Text="Timeout SOAP" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,12" />

                    <CheckBox Grid.Row="5" Grid.Column="1" Content="Ricorda password con DPAPI per l'utente Windows corrente" IsChecked="{Binding RememberCredentials}" Margin="0,0,0,10" />
                    <CheckBox Grid.Row="6" Grid.Column="1" Content="Abilita logging diagnostico SOAP (senza password)" IsChecked="{Binding DiagnosticSoapLoggingEnabled}" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="7" Text="Cerca prima del" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SearchBeforeDate, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,12" />

                    <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,8,0,0">
                        <Button Content="Carica" Command="{Binding LoadCommand}" Width="96" Margin="0,0,8,0" />
                        <Button Content="Salva" Command="{Binding SaveCommand}" Width="96" Margin="0,0,8,0" />
                        <Button Content="Test connessione" Command="{Binding TestConnectionCommand}" Width="130" Margin="0,0,8,0" />
                        <Button Content="Test ricerca" Command="{Binding TestSearchCommand}" Width="110" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Log">
                <Grid Margin="0,18,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Aggiorna" Command="{Binding RefreshLogsCommand}" Width="96" Margin="0,0,12,0" />
                        <Button Content="Copia tutto" Command="{Binding CopyLogsCommand}" Width="96" Margin="0,0,12,0" />
                        <TextBlock Text="{Binding LogDirectory}" VerticalAlignment="Center" Foreground="#555" />
                    </StackPanel>
                    <TextBox Grid.Row="1"
                             Text="{Binding RecentLogText, Mode=OneWay}"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1,0,0,0" Padding="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#333" />
        </Border>
    </Grid>
</Window>
